{
  "schemaVersion": 1,
  "kind": "dashboard",
  "id": "dash_fleet_utilization",
  "name": "Fleet Utilization",
  "grid": { "cols": 12, "rowHeight": 40, "margin": [12, 12] },
  "variables": [
    { "name": "dateRange", "type": "dateRange", "label": "Date range", "default": "last 7 days" },
    { "name": "granularity", "type": "granularity", "label": "Granularity", "default": "day" }
  ],
  "layout": [
    { "i": "w_dateRange", "x": 0, "y": 0, "w": 4, "h": 2, "minW": 3, "minH": 2 },
    { "i": "w_granularity", "x": 4, "y": 0, "w": 4, "h": 2, "minW": 3, "minH": 2 },
    { "i": "w_distance", "x": 0, "y": 2, "w": 7, "h": 5, "minW": 3, "minH": 3 },
    { "i": "w_trips", "x": 7, "y": 2, "w": 5, "h": 5, "minW": 3, "minH": 3 },
    { "i": "w_text", "x": 0, "y": 7, "w": 12, "h": 4, "minW": 3, "minH": 2 }
  ],
  "widgets": [
    {
      "id": "w_dateRange",
      "type": "input",
      "title": "Date range",
      "control": {
        "variable": "dateRange",
        "control": {
          "kind": "dateRange",
          "allowFuture": false,
          "presets": ["last 7 days", "last 30 days", "last 90 days", "this year"]
        }
      }
    },
    {
      "id": "w_granularity",
      "type": "input",
      "title": "Granularity",
      "control": {
        "variable": "granularity",
        "control": { "kind": "granularity", "options": ["day", "week", "month"] }
      }
    },
    {
      "id": "w_text",
      "type": "text",
      "title": "Notes",
      "doc": {
        "type": "doc",
        "content": [
          { "type": "heading", "attrs": { "level": 1 }, "content": [{ "type": "text", "text": "Fleet Overview" }] },
          { "type": "paragraph", "content": [{ "type": "text", "text": "Key metrics for the selected period. " }, { "type": "text", "marks": [{ "type": "bold" }], "text": "Distance is in km." }] },
          { "type": "heading", "attrs": { "level": 2 }, "content": [{ "type": "text", "text": "Highlights" }] },
          { "type": "bulletList", "content": [
            { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Total distance by vehicle" }] }] },
            { "type": "listItem", "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Trip counts per device" }] }] }
          ] }
        ]
      }
    },
    {
      "id": "w_distance",
      "type": "chart",
      "title": "Total Distance Over Time",
      "query": {
        "measures": ["device_trips.total_distance"],
        "timeDimensions": [
          {
            "dimension": "device_trips.start_time",
            "granularity": { "var": "granularity" },
            "dateRange": { "var": "dateRange" }
          }
        ],
        "order": [["device_trips.start_time", "asc"]],
        "limit": 5000
      },
      "chart": {
        "family": "line",
        "mapping": {
          "category": { "member": "device_trips.start_time" },
          "series": {
            "mode": "measures",
            "members": ["device_trips.total_distance"],
            "meta": { "device_trips.total_distance": { "label": "Distance", "colorToken": "chart-1" } }
          }
        },
        "legend": { "show": false },
        "tooltip": { "show": true, "indicator": "line" }
      }
    },
    {
      "id": "w_trips",
      "type": "chart",
      "title": "Trip Count by Device",
      "query": {
        "measures": ["device_trips.count"],
        "dimensions": ["devices.name"],
        "timeDimensions": [
          { "dimension": "device_trips.start_time", "dateRange": { "var": "dateRange" } }
        ],
        "order": { "device_trips.count": "desc" },
        "limit": 10
      },
      "chart": {
        "family": "bar",
        "orientation": "horizontal",
        "stackMode": "none",
        "mapping": {
          "category": { "member": "devices.name" },
          "series": {
            "mode": "measures",
            "members": ["device_trips.count"],
            "meta": { "device_trips.count": { "label": "Trips", "colorToken": "chart-3" } }
          }
        },
        "legend": { "show": false },
        "tooltip": { "show": true, "indicator": "dot" }
      }
    }
  ]
}
