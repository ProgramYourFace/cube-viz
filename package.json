{
  "name": "cube-viz",
  "version": "0.2.0",
  "description": "Render and edit JSON dashboard/chart specs backed by Cube. shadcn/Recharts renderer, react-grid-layout, TipTap. Web-first, embeddable in a mobile WebView.",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./theme.css": "./dist/theme.css",
    "./styles.css": "./dist/cube-viz.css"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.config.lib.ts && cp src/theme/tokens.css dist/theme.css",
    "build:playground": "vite build",
    "preview:playground": "vite preview",
    "typecheck": "tsc --noEmit",
    "shot": "bun playground/shot.mjs"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@cubejs-client/core": "^1.6.60",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convert-units": "^3.0.0-beta.6",
    "date-fns": "^4.1.0",
    "html-to-image": "^1.11.13",
    "lucide-react": "^0.469.0",
    "react-day-picker": "^9",
    "react-grid-layout": "^2.2.3",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-grid-layout": "^1.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.61.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0"
  }
}
