# cube-viz playground — copy to `.env` (gitignored) for LOCAL live-data preview.
# The Vite dev server (playground/vite-cube-dev.ts) reads these to mint a Cube JWT
# locally and proxy the Cube REST API same-origin. The secret never reaches the
# browser; it stays in this local file.

# Cube REST endpoint. May be the host (https://xxx.cubecloudapp.dev) or include
# the REST path — the proxy normalizes to <origin>/cubejs-api/v1.
CUBE_API_URL=

# The Cube API secret used to sign the JWT (HS256). Local-only.
CUBE_API_SECRET=

# Optional: override the dev security context (defaults to admin / all tenants).
# CUBE_DEV_ROLES=tenant
# CUBE_DEV_SYSTEM_IDS=jd7b2rssfj02tk8kt58vw4chb97zqqet
